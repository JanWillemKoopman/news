# MMM — environment variables. Copy to .env.local (frontend) / Modal Secret (worker).
# NEVER commit real secret keys. The publishable key is safe to expose (client-side);
# the service_role key and DB password are secret and belong only in server env / secrets.

# --- Supabase (project "MMM", eu-central-1) ---
NEXT_PUBLIC_SUPABASE_URL=https://pzpoptfljgrskebnuggt.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ph-BpC3ftPyPMpbUzuM--A_2yxvz2Kq
# Secret — server/worker only. Get from Supabase > Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=

# MMM lives in its own Postgres schema (isolated from the project's other tables).
MMM_DB_SCHEMA=mmm
MMM_RAW_BUCKET=mmm-raw-data
MMM_ARTIFACTS_BUCKET=mmm-artifacts

# --- Modal (worker) ---
# Configured via `modal token new` locally; the worker reads Supabase vars from the
# Modal Secret `mmm-supabase`, not from here.

# --- Anthropic (PRODUCTION app only — separate from the Claude Code build session) ---
ANTHROPIC_API_KEY=
