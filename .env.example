# Gemini API sleutel (verplicht)
GEMINI_API_KEY=jouw_gemini_api_sleutel_hier

# Gemini modellen
RESEARCHER_MODEL=gemini-2.0-flash
SUMMARIZER_MODEL=gemini-2.0-flash

# Nieuwsbronnen (komma-gescheiden)
NEWS_SOURCES=nu.nl, nos.nl, volkskrant.nl, ad.nl, rtlnieuws.nl

# Scheduler: elke zondag om 16:00 (Europe/Amsterdam)
SCHEDULE_DAY=sun
SCHEDULE_HOUR=16
SCHEDULE_MINUTE=0
TIMEZONE=Europe/Amsterdam

# Pagina-grootte (aantal samenvattingen per keer)
PAGE_SIZE=5

# Server poort
PORT=5000
