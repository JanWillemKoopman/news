# Gemini API sleutel (verplicht)
GEMINI_API_KEY=jouw_gemini_api_sleutel_hier

# Supabase (verplicht voor login + bedrijfsprofiel)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sb_publishable_… of legacy anon JWT>
SUPABASE_SERVICE_ROLE_KEY=<sb_secret_… of legacy service_role JWT — alleen server-side>


# Gemini modellen
RESEARCHER_MODEL=gemini-2.0-flash
SUMMARIZER_MODEL=gemini-2.0-flash

# Nieuwsbronnen (komma-gescheiden)
NEWS_SOURCES=nu.nl, nos.nl, volkskrant.nl, ad.nl, rtlnieuws.nl

# Scheduler: elke zondag om 16:00 (Europe/Amsterdam)
SCHEDULE_DAY=sun
SCHEDULE_HOUR=16
SCHEDULE_MINUTE=0
TIMEZONE=Europe/Amsterdam

# Geheim token voor het handmatig starten van een update (willekeurige lange string)
TRIGGER_SECRET=kies_hier_een_lang_willekeurig_wachtwoord

# Pagina-grootte (aantal samenvattingen per keer)
PAGE_SIZE=5

# Server poort
PORT=5000
