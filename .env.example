# Supabase — kopieer naar .env.local en vul in.
# Project-instellingen: https://supabase.com/dashboard/project/_/settings/api
# Bij lokale ontwikkeling levert `npx supabase start` deze waarden.

# Publiek (veilig in de browser-bundle):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NOOIT in de client; alleen in serveromgeving/Vercel-secrets):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basis-URL voor auth-redirects (bevestiging/wachtwoordherstel).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini (server-only): wordt gebruikt voor de AI-vormgeving van de publieke
# RSVP-pagina. Maak een key aan op https://aistudio.google.com/app/apikey en
# zet 'm in .env.local — NIET committen.
GEMINI_API_KEY=your-gemini-api-key
