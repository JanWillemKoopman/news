# Supabase — kopieer naar .env.local en vul in.
# Project-instellingen: https://supabase.com/dashboard/project/_/settings/api
# Bij lokale ontwikkeling levert `npx supabase start` deze waarden.

# Publiek (veilig in de browser-bundle):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NOOIT in de client; alleen in serveromgeving/Vercel-secrets):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basis-URL voor auth-redirects (bevestiging/wachtwoordherstel).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E-mail via Resend (https://resend.com/api-keys).
# Server-only: NOOIT een NEXT_PUBLIC_-prefix gebruiken.
RESEND_API_KEY=your-resend-api-key

# Geheim voor de dagelijkse herinneringen-cron (server-only).
# Vercel Cron stuurt dit automatisch mee als 'Authorization: Bearer <CRON_SECRET>'.
# Bij een andere scheduler: stuur dezelfde header mee naar /api/cron/reminders.
CRON_SECRET=your-cron-secret

# Google Gemini API — voor AI-advies op het dashboard en de budgetpagina (server-only).
# Aanmaken via https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
