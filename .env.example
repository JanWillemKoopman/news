# Supabase — kopieer naar .env.local en vul in.
# Project-instellingen: https://supabase.com/dashboard/project/_/settings/api
# Bij lokale ontwikkeling levert `npx supabase start` deze waarden.

# Publiek (veilig in de browser-bundle):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NOOIT in de client; alleen in serveromgeving/Vercel-secrets):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basis-URL voor auth-redirects (bevestiging/wachtwoordherstel).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E-mail via Resend (https://resend.com/api-keys).
# Server-only: NOOIT een NEXT_PUBLIC_-prefix gebruiken.
RESEND_API_KEY=your-resend-api-key

# Geheim voor de dagelijkse herinneringen-cron (server-only).
# Vercel Cron stuurt dit automatisch mee als 'Authorization: Bearer <CRON_SECRET>'.
# Bij een andere scheduler: stuur dezelfde header mee naar /api/cron/reminders.
CRON_SECRET=your-cron-secret

# HMAC-sleutel voor de "ontgrendel"-cookie van het site-brede
# trouwwebsite-wachtwoord (server-only). Genereer bijv. met:
# openssl rand -hex 32
SITE_PASSWORD_SECRET=your-site-password-secret

# Google Gemini API — voor het importeren van een gastenlijst (server-only).
# Aanmaken via https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Sentry fout-tracking — DSN vinden via sentry.io → Project → Settings → Client Keys.
# NEXT_PUBLIC_ prefix is vereist zodat de browser-SDK de DSN kan lezen.
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@oXXXXXX.ingest.sentry.io/YYYYYYY

# Sentry source map upload (optioneel maar aanbevolen voor leesbare stack traces in productie).
# Auth token aanmaken via sentry.io → Settings → Auth Tokens (scope: project:releases).
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# Geheim voor Sentry webhook-verificatie (server-only).
# Sentry genereert dit bij het aanmaken van de webhook:
# sentry.io → Project Settings → WebHooks → Client Secret
SENTRY_WEBHOOK_SECRET=your-sentry-webhook-secret
